@startuml
skinparam conditionStyle inside
title Алгоритм системы верификации пути "Гуси-лебеди"

start

:Девочка: начать поиск брата;
:Брат похищен гусями-лебедями;

partition "Встреча с Печкой" {
    :Девочка: попросить помощи у Печки;
    
    if (Девочка: съела пирожок?) then (да)
        #lightgreen:Печка: предоставить убежище;
        :Девочка: спрятаться;
    else (нет)
        :Печка: отказать в помощи;
        :Девочка: идти дальше;
    endif
}

partition "Встреча с Яблоней" {
    :Девочка: попросить помощи у Яблони;
    
    if (Девочка: съела яблоко?) then (да)
        #lightgreen:Яблоня: предоставить убежище;
        :Девочка: спрятаться;
    else (нет)
        :Яблоня: отказать в помощи;
        :Девочка: идти дальше;
    endif
}

partition "Встреча с Речкой" {
    :Девочка: попросить помощи у Речки;
    
    if (Девочка: съела кисель?) then (да)
        #lightgreen:Речка: предоставить убежище;
        :Девочка: спрятаться;
    else (нет)
        :Речка: отказать в помощи;
        :Девочка: идти дальше;
    endif
}

partition "Погоня гусей-лебедей" {
    :Гуси-лебеди: лететь за Девочкой;
    
    if (Девочка: спряталась?) then (да)
        #lightgreen:Девочка: скрыта от погони;
        :Девочка: продолжить поиск;
    else (нет)
        #pink:Гуси-лебеди: схватить Девочку;
        :Провал!;
        stop
    endif
}

:Девочка: найти брата;
#lightgreen:Успешное спасение!;

stop
@enduml
