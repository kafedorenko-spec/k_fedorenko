@startuml
skinparam state {
  BackgroundColor<<Hidden>> #lightgreen
  BackgroundColor<<Caught>> #pink
}

title Локация девочки в системе "Гуси-лебеди"

[*] --> ВПоле : <<create>>

state "В поле (InOpenArea)" as ВПоле
state "Скрыта (Hidden)" as Скрыта <<Hidden>>
state "Поймана" as Поймана <<Caught>>
state c1 <<choice>>
state c2 <<choice>>

' Все воздействия идут в точку принятия решения
ВПоле --> c1 : гусиЛетят()

' Логика распределения потоков
c1 --> Скрыта : [объектПомог && съеденыПродукты] \n (Девочка спряталась)
c1 --> Поймана : [!объектПомог || !съеденыПродукты] \n (Девочка схвачена)

' Переход от скрытого состояния
Скрыта --> c2 : гусиУлетели()

' Логика возврата
c2 --> [*] : [братСпасен] \n Успех!
c2 --> ВПоле : [братНеСпасен] \n Продолжить поиск

' Финал
Поймана --> [*] : <<destroy>>

note left of c1
  **Точка выбора (Choice 1)**
  Проверяет условие:
  если объект помог И 
  продукты съедены → Скрыта
  иначе → Поймана
end note

note right of c2
  **Точка выбора (Choice 2)**
  Проверяет условие:
  если брат спасён → Успех
  если брат не спасён → 
  возврат в поле
end note

note bottom of Скрыта
  Девочка спрятана внутри
  Печки, Яблони или Речки
end note

@enduml
